# ============================================================================
# Stock Verify Frontend - Production Environment
# ============================================================================
# Copy to .env for production builds (EAS Build)
# ============================================================================

# ----------------------------------------------------------------------------
# Backend Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# Set this to your production backend URL (HTTPS recommended)
EXPO_PUBLIC_BACKEND_PORT=8001
EXPO_PUBLIC_BACKEND_URL=https://your-production-domain.com

# ----------------------------------------------------------------------------
# Production Configuration
# ----------------------------------------------------------------------------
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=false

# ----------------------------------------------------------------------------
# Monitoring (Recommended)
# ----------------------------------------------------------------------------
# Add your public Sentry DSN to enable frontend error reporting
# EXPO_PUBLIC_SENTRY_DSN=https://<public_key>@o0.ingest.sentry.io/<project_id>
EXPO_PUBLIC_APP_ENV=production
