{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://stock.lavanyaemart.app",
        "EXPO_PUBLIC_INTERNET_BACKEND_URL": "https://stock.lavanyaemart.app",
        "EXPO_PUBLIC_API_TIMEOUT": "30000"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://stock.lavanyaemart.app",
        "EXPO_PUBLIC_INTERNET_BACKEND_URL": "https://stock.lavanyaemart.app",
        "EXPO_PUBLIC_API_TIMEOUT": "30000"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
