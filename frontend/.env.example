# ============================================================================
# Stock Verify Frontend - Environment Configuration
# ============================================================================
# SECURITY WARNING: Never commit actual .env files to version control!
# This is a template file. Copy to .env and fill in your actual values.
# ============================================================================

# ----------------------------------------------------------------------------
# Backend Configuration
# ----------------------------------------------------------------------------
# Port is used for dynamic URL detection when running locally
EXPO_PUBLIC_BACKEND_PORT=8001

# Optional: Set this to override automatic IP detection
# For production, set this to your backend URL
# EXPO_PUBLIC_BACKEND_URL=http://your-backend-server:8001

# ----------------------------------------------------------------------------
# Development Configuration
# ----------------------------------------------------------------------------
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_DEBUG_MODE=false
# Optional: set to true only when reactotron-react-native is installed locally
EXPO_PUBLIC_ENABLE_REACTOTRON=false

# ----------------------------------------------------------------------------
# Network Configuration
# ----------------------------------------------------------------------------
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=false

# ----------------------------------------------------------------------------
# Monitoring (Optional)
# ----------------------------------------------------------------------------
# Public Sentry DSN for frontend crash/error reporting
# EXPO_PUBLIC_SENTRY_DSN=https://<public_key>@o0.ingest.sentry.io/<project_id>
EXPO_PUBLIC_APP_ENV=development
