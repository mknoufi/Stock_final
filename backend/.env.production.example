# ============================================================================
# Stock Verify Application - Environment Configuration (PRODUCTION)
# ============================================================================
# SECURITY WARNING: Never commit actual .env files to version control!
# This is a template file. Copy to .env and fill in your actual values.
# ============================================================================
#
# IMPORTANT: All values below MUST be replaced with actual production values
# before deploying to production environment.
#
# Generate secure secrets using: python backend/utils/secret_generator.py
# ============================================================================

# ----------------------------------------------------------------------------
# MongoDB Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# Production MongoDB connection string
# Use MongoDB Atlas or your production MongoDB instance
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Database name
DB_NAME=stock_verify_production

# ----------------------------------------------------------------------------
# JWT Configuration (REQUIRED - CRITICAL SECURITY)
# ----------------------------------------------------------------------------
# IMPORTANT: Generate secure secrets using: python backend/utils/secret_generator.py
# These MUST be set to cryptographically secure random strings (min 32 chars)
# DO NOT use the example values below in production!
JWT_SECRET=GENERATE_SECURE_SECRET_HERE_MIN_32_CHARS
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_SECURE_SECRET_HERE_MIN_32_CHARS
JWT_ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------------------------------------------------------
# PIN Security (REQUIRED - CRITICAL SECURITY)
# ----------------------------------------------------------------------------
# PIN salt for PIN lookup hashing
# Generate a secure random string and set it here
# This is critical for PIN security - DO NOT use default values
PIN_SALT=GENERATE_SECURE_RANDOM_SALT_HERE_MIN_32_CHARS

# ----------------------------------------------------------------------------
# SQL Server Configuration (Optional - for ERP integration)
# ----------------------------------------------------------------------------
# Leave empty if not using SQL Server ERP integration
SQL_SERVER_HOST=
SQL_SERVER_PORT=1433
SQL_SERVER_DATABASE=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=

# Performance tuning (if SQL Server is used)
SYNC_BATCH_SIZE=1000
PARALLEL_SYNC_WORKERS=4

# ----------------------------------------------------------------------------
# Redis Configuration (Optional - recommended for production)
# ----------------------------------------------------------------------------
# Uncomment and configure if using Redis for caching and session management
# REDIS_URL=redis://<redis-host>:6379/0
# REDIS_PASSWORD=<redis-password-if-auth-enabled>

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
LOG_LEVEL=WARNING
ENVIRONMENT=production
APP_NAME=Stock Verify API
APP_VERSION=2.0.0

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Server port
PORT=8001

# Number of worker processes (recommended: 2-4 for production)
WORKERS=4

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
# Cache time-to-live in seconds (1800 = 30 minutes)
CACHE_TTL=1800

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# Rate limiting configuration (requests per minute)
RATE_LIMIT_PER_MINUTE=50
RATE_LIMIT_BURST=10
MAX_CONCURRENT=50

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# ----------------------------------------------------------------------------
# Connection Pool
# ----------------------------------------------------------------------------
# Database connection pool settings
USE_CONNECTION_POOL=true
POOL_SIZE=10
MAX_OVERFLOW=5

# ----------------------------------------------------------------------------
# Security Settings (PRODUCTION)
# ----------------------------------------------------------------------------
# Enable strict Content Security Policy
STRICT_CSP=true

# Force HTTPS (set to true in production)
FORCE_HTTPS=true

# SSL certificate paths (if using custom certificates)
# SSL_KEYFILE=/path/to/ssl/privkey.pem
# SSL_CERTFILE=/path/to/ssl/fullchain.pem

# Disable SSL (only for development, never in production)
DISABLE_SSL=false

# ----------------------------------------------------------------------------
# Sync Services
# ----------------------------------------------------------------------------
# Enable/disable ERP sync
ERP_SYNC_ENABLED=false

# Enable/disable change detection sync
CHANGE_DETECTION_SYNC_ENABLED=true

# Change detection interval in seconds (300 = 5 minutes)
CHANGE_DETECTION_INTERVAL=300

# ----------------------------------------------------------------------------
# CORS Configuration (PRODUCTION)
# ----------------------------------------------------------------------------
# Production frontend URLs (comma-separated)
# Replace with your actual production frontend URLs
CORS_DEV_ORIGINS=https://your-frontend-domain.com,https://app.your-domain.com

# ----------------------------------------------------------------------------
# OpenTelemetry Tracing (Optional)
# ----------------------------------------------------------------------------
# Enable distributed tracing
STOCK_VERIFY_TRACING_ENABLED=false

# OTLP endpoint for traces
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Service name for tracing
STOCK_VERIFY_SERVICE_NAME=stock-verify-backend

# ----------------------------------------------------------------------------
# Monitoring & Observability
# ----------------------------------------------------------------------------
# Enable health checks
ENABLE_HEALTH_CHECKS=true

# Enable metrics collection
ENABLE_METRICS=true

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# ----------------------------------------------------------------------------
# Backup & Maintenance
# ----------------------------------------------------------------------------
# Enable automatic backups
ENABLE_AUTO_BACKUP=false

# Backup interval in hours
BACKUP_INTERVAL_HOURS=24

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
#
# [ ] JWT_SECRET and JWT_REFRESH_SECRET are set to secure random strings
# [ ] PIN_SALT is set to a secure random string
# [ ] MONGO_URL points to production MongoDB instance
# [ ] FORCE_HTTPS is set to true
# [ ] STRICT_CSP is set to true
# [ ] LOG_LEVEL is set to WARNING or ERROR
# [ ] WORKERS is set to appropriate value (2-4)
# [ ] RATE_LIMIT_ENABLED is set to true
# [ ] CORS_DEV_ORIGINS contains only production URLs
# [ ] DISABLE_SSL is set to false
# [ ] All default/example values have been replaced
# [ ] .env file is NOT committed to version control
# [ ] Backup and recovery procedures are tested
# [ ] SSL certificates are properly configured
# [ ] Database backups are configured
# [ ] Monitoring and alerting are set up
# ============================================================================
