# ============================================================================
# Stock Verify - Canonical Docker Compose production environment
# Copy this file to .env.prod before running:
#   cp .env.production.example .env.prod
# ============================================================================

# ----------------------------------------------------------------------------
# Public domain and TLS
# ----------------------------------------------------------------------------
DOMAIN=stock-verify.example.com
CERTBOT_EMAIL=ops@example.com

# ----------------------------------------------------------------------------
# Backend runtime
# ----------------------------------------------------------------------------
DB_NAME=stock_verification
BACKEND_WORKERS=4
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_REFRESH_SECRET
LOG_LEVEL=INFO
FORCE_HTTPS=true
ALLOWED_HOSTS=stock-verify.example.com,www.stock-verify.example.com
CORS_ALLOW_ORIGINS=https://stock-verify.example.com,https://www.stock-verify.example.com
AUTH_COOKIE_DOMAIN=.stock-verify.example.com
AUTH_COOKIE_SAMESITE=lax
AUTO_SEED_DEFAULT_USERS=false
AUTO_SEED_MOCK_ERP_DATA=false

# Optional observability
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# METRICS_ENABLED=true

# ----------------------------------------------------------------------------
# MongoDB / Redis
# ----------------------------------------------------------------------------
MONGO_ROOT_USER=stockverify
MONGO_ROOT_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_MONGO_PASSWORD
REDIS_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD

# ----------------------------------------------------------------------------
# Frontend web build
# Leave EXPO_PUBLIC_BACKEND_URL unset for same-origin /api proxying through nginx.
# ----------------------------------------------------------------------------
EXPO_PUBLIC_API_TIMEOUT=30000
