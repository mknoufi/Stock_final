# =============================================================================
# Stock Verification System — .gitignore
# =============================================================================

# Environment files (secrets)
.env
.env.bak
.env.local
.env.production

# Keep example templates
!.env.example
!.env.production.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.spec
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
*.log.*
app.log

# Build artifacts
*.exe
*.dll
*.so

# Temporary files
*.tmp
*.bak
*.orig

# Agent / AI assistant config leftovers
.aider*
.autogpt.yml
.autopilot.json
.clinerules
.cursorrules
.devon.yml
.interpreter.yml
.kilocodemodes
.swe-agent.yml
.secrets.baseline
cooking_agent/

# Test output
*_output.txt
*_results.txt
*_results_*.txt
test_failures.txt
pre_commit_output.txt

# Docker
.dockerignore

# Expo
.expo/
backend/venv/
